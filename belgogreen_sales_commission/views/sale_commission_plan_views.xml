<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit Form View to add hierarchical fields -->
        <record id="view_sale_commission_plan_form_inherit" model="ir.ui.view">
            <field name="name">sale.commission.plan.form.inherit</field>
            <field name="model">sale.commission.plan</field>
            <field name="inherit_id" ref="sale_commission.sale_commission_plan_view_form"/>
            <field name="arch" type="xml">
                <!-- Add smart button for commissions -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_commissions"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-sitemap"
                            groups="belgogreen_sales_commission.group_commission_user">
                        <field name="commission_count" widget="statinfo" string="Commissions"/>
                    </button>
                </xpath>

                <!-- Add configuration tab -->
                <xpath expr="//notebook" position="inside">
                    <page string="Configuration" name="configuration">
                        <group>
                            <group string="Commission Calculation Settings">
                                <field name="is_hierarchical"/>
                                <div class="text-muted" style="margin-left: 20px;">
                                    Enable this option to automatically calculate commissions for the entire sales hierarchy.
                                    When enabled, commissions will be distributed across Salesperson, Team Leader, and Sales Director
                                    based on the percentages defined in the "Role Percentages" tab.
                                </div>
                            </group>
                            <group string="Payment Requirements">
                                <field name="require_invoice_paid"/>
                                <div class="text-muted" style="margin-left: 20px;">
                                    If enabled, commissions will only be generated when the customer invoice is fully paid.
                                    If disabled, commissions will be created as soon as the invoice is posted/confirmed,
                                    regardless of payment status.
                                </div>
                            </group>
                        </group>
                    </page>

                    <!-- Add role configuration tab -->
                    <page string="Role Percentages" name="role_config" invisible="not is_hierarchical">
                        <field name="role_config_ids">
                            <list editable="bottom">
                                <field name="role"/>
                                <field name="default_percentage"/>
                                <field name="active"/>
                            </list>
                        </field>
                        <group>
                            <div class="alert alert-info" role="alert">
                                <strong>Note:</strong> Define the commission percentage for each role in the hierarchy.
                                These percentages will be applied automatically when commissions are calculated.
                            </div>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- Action for Commission Plans -->
        <record id="action_sale_commission_plan" model="ir.actions.act_window">
            <field name="name">Commission Plans</field>
            <field name="res_model">sale.commission.plan</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a commission plan
                </p>
                <p>
                    Define commission plans with hierarchical percentages for different roles.
                </p>
            </field>
        </record>

    </data>
</odoo>
