<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Tree View -->
        <record id="view_sale_commission_payment_tree" model="ir.ui.view">
            <field name="name">sale.commission.payment.tree</field>
            <field name="model">sale.commission.payment</field>
            <field name="arch" type="xml">
                <list string="Commission Payments" decoration-success="state == 'paid'" decoration-info="state == 'confirmed'" decoration-muted="state == 'cancelled'">
                    <field name="name"/>
                    <field name="user_id"/>
                    <field name="payment_date"/>
                    <field name="commission_count"/>
                    <field name="total_amount" sum="Total"/>
                    <field name="payment_method"/>
                    <field name="state"/>
                    <field name="currency_id" column_invisible="True"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_sale_commission_payment_form" model="ir.ui.view">
            <field name="name">sale.commission.payment.form</field>
            <field name="model">sale.commission.payment</field>
            <field name="arch" type="xml">
                <form string="Commission Payment">
                    <header>
                        <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_mark_paid" string="Mark as Paid" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state in ['paid', 'cancelled']" confirm="Are you sure you want to cancel this payment?"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,paid"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_commissions"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-list">
                                <field name="commission_count" widget="statinfo" string="Commissions"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Payment Details">
                                <field name="user_id" readonly="state != 'draft'"/>
                                <field name="payment_date" readonly="state == 'paid'"/>
                                <field name="payment_method" readonly="state == 'paid'"/>
                            </group>
                            <group string="Amount">
                                <field name="currency_id" invisible="1"/>
                                <field name="total_amount" class="oe_subtotal_footer_separator"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Commissions" name="commissions">
                                <field name="commission_ids" readonly="state != 'draft'" context="{'default_user_id': user_id}">
                                    <list decoration-success="payment_status == 'paid'" decoration-warning="payment_status == 'claimed'">
                                        <field name="name"/>
                                        <field name="date"/>
                                        <field name="role"/>
                                        <field name="sale_order_id"/>
                                        <field name="base_amount"/>
                                        <field name="commission_amount" sum="Total"/>
                                        <field name="payment_status"/>
                                        <field name="can_be_paid" column_invisible="True"/>
                                        <field name="currency_id" column_invisible="True"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notes" name="notes">
                                <field name="notes" placeholder="Payment notes..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_sale_commission_payment_search" model="ir.ui.view">
            <field name="name">sale.commission.payment.search</field>
            <field name="model">sale.commission.payment</field>
            <field name="arch" type="xml">
                <search string="Commission Payments">
                    <field name="name"/>
                    <field name="user_id"/>
                    <field name="payment_date"/>
                    <separator/>
                    <filter string="My Payments" name="my_payments" domain="[('user_id', '=', uid)]"/>
                    <separator/>
                    <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <filter string="Paid" name="paid" domain="[('state', '=', 'paid')]"/>
                    <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
                    <separator/>
                    <filter string="This Month" name="this_month"
                            domain="[('payment_date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                     ('payment_date', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>
                    <group expand="0" string="Group By">
                        <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                        <filter string="Payment Method" name="group_method" context="{'group_by': 'payment_method'}"/>
                        <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Payment Date" name="group_date" context="{'group_by': 'payment_date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Kanban View -->
        <record id="view_sale_commission_payment_kanban" model="ir.ui.view">
            <field name="name">sale.commission.payment.kanban</field>
            <field name="model">sale.commission.payment</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile">
                    <field name="name"/>
                    <field name="user_id"/>
                    <field name="total_amount"/>
                    <field name="payment_date"/>
                    <field name="state"/>
                    <field name="commission_count"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    </div>
                                    <span class="float-end badge badge-pill"
                                          t-attf-class="#{record.state.raw_value == 'paid' ? 'badge-success' : record.state.raw_value == 'confirmed' ? 'badge-info' : 'badge-secondary'}">
                                        <field name="state"/>
                                    </span>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="user_id"/>
                                    <br/>
                                    <strong><field name="total_amount"/></strong> (<field name="commission_count"/> commissions)
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="payment_date"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Action -->
        <record id="action_sale_commission_payment" model="ir.actions.act_window">
            <field name="name">Commission Payments</field>
            <field name="res_model">sale.commission.payment</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a commission payment
                </p>
                <p>
                    Group multiple commissions into a single payment batch for easier processing.
                </p>
            </field>
        </record>

    </data>
</odoo>
