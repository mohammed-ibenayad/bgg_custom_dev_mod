<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Team Hierarchy Tree View -->
        <record id="view_team_hierarchy_tree" model="ir.ui.view">
            <field name="name">team.hierarchy.tree</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <list string="Team Hierarchy" decoration-info="commission_role == 'sales_director'"
                      decoration-success="commission_role == 'team_leader'"
                      decoration-muted="not commission_role">
                    <field name="name" string="Nom" width="150px"/>
                    <field name="commission_role" string="Rôle" width="120px"/>
                    <field name="sales_director_id" string="Directeur" width="130px"/>
                    <field name="team_leader_id" string="Chef d'équipe" width="130px"/>
                    <field name="subordinate_count" string="N. subordonnés" width="100px"/>
                    <field name="active_commission_count" string="Com. actives" width="100px"/>
                    <field name="commission_unpaid_total" string="Non payé" sum="Total non payé" width="110px"/>
                    <field name="team_unpaid_total" string="Équipe non payée" sum="Total équipe" width="120px"/>
                </list>
            </field>
        </record>

        <!-- Team Hierarchy Kanban View -->
        <record id="view_team_hierarchy_kanban" model="ir.ui.view">
            <field name="name">team.hierarchy.kanban</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" create="false">
                    <field name="name"/>
                    <field name="commission_role"/>
                    <field name="sales_director_id"/>
                    <field name="team_leader_id"/>
                    <field name="subordinate_count"/>
                    <field name="active_commission_count"/>
                    <field name="commission_unpaid_total"/>
                    <field name="team_unpaid_total"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><field name="name"/></strong>
                                        <br/>
                                        <span class="badge"
                                              t-att-class="{'badge-primary': record.commission_role.raw_value == 'sales_director',
                                                            'badge-success': record.commission_role.raw_value == 'team_leader',
                                                            'badge-info': record.commission_role.raw_value == 'salesperson'}">
                                            <field name="commission_role"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div t-if="record.sales_director_id.value">
                                        <strong>Directeur :</strong> <field name="sales_director_id"/>
                                    </div>
                                    <div t-if="record.team_leader_id.value">
                                        <strong>Chef d'équipe :</strong> <field name="team_leader_id"/>
                                    </div>
                                    <div t-if="record.subordinate_count.value > 0">
                                        <strong>Subordonnés :</strong> <field name="subordinate_count"/>
                                    </div>
                                    <div>
                                        <strong>Com. actives :</strong> <field name="active_commission_count"/>
                                    </div>
                                    <div>
                                        <strong>Non payé :</strong> <field name="commission_unpaid_total"/>
                                    </div>
                                    <div t-if="record.team_unpaid_total.value > 0">
                                        <strong>Équipe non payée :</strong> <field name="team_unpaid_total"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Team Hierarchy Search View -->
        <record id="view_team_hierarchy_search" model="ir.ui.view">
            <field name="name">team.hierarchy.search</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <search string="Team Hierarchy">
                    <field name="name"/>
                    <field name="commission_role"/>
                    <field name="sales_director_id"/>
                    <field name="team_leader_id"/>
                    <separator/>
                    <filter string="Sales Directors" name="sales_directors" domain="[('commission_role', '=', 'sales_director')]"/>
                    <filter string="Team Leaders" name="team_leaders" domain="[('commission_role', '=', 'team_leader')]"/>
                    <filter string="Salespeople" name="salespeople" domain="[('commission_role', '=', 'salesperson')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Commission Role" name="group_role" context="{'group_by': 'commission_role'}"/>
                        <filter string="Sales Director" name="group_director" context="{'group_by': 'sales_director_id'}"/>
                        <filter string="Team Leader" name="group_team_leader" context="{'group_by': 'team_leader_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Team Hierarchy Action -->
        <record id="action_team_hierarchy" model="ir.actions.act_window">
            <field name="name">Team Hierarchy</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="domain">[('commission_role', '!=', False)]</field>
            <field name="context">{'search_default_group_director': 1}</field>
            <field name="search_view_id" ref="view_team_hierarchy_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No commission hierarchy defined yet
                </p>
                <p>
                    Set up your sales team hierarchy by assigning commission roles to users.
                </p>
            </field>
        </record>

        <!-- Team Management Dashboard View (Graph) -->
        <record id="view_team_management_graph" model="ir.ui.view">
            <field name="name">team.management.graph</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <graph string="Team Performance" type="bar">
                    <field name="commission_role" type="row"/>
                    <field name="commission_unpaid_total" type="measure"/>
                </graph>
            </field>
        </record>

        <!-- Team Management Dashboard Action -->
        <record id="action_team_management_dashboard" model="ir.actions.act_window">
            <field name="name">Team Management Dashboard</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">kanban,list,graph,form</field>
            <field name="domain">[('commission_role', 'in', ['team_leader', 'sales_director'])]</field>
            <field name="context">{}</field>
            <field name="search_view_id" ref="view_team_hierarchy_search"/>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_team_hierarchy_kanban')}),
                (0, 0, {'view_mode': 'list', 'view_id': ref('view_team_hierarchy_tree')}),
                (0, 0, {'view_mode': 'graph', 'view_id': ref('view_team_management_graph')})]"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No teams found
                </p>
                <p>
                    Teams will appear here once you assign Team Leaders and Sales Directors.
                </p>
            </field>
        </record>

    </data>
</odoo>
