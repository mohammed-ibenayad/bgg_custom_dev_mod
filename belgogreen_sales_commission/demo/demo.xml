    <!-- ============================================ -->
    <!-- Demo Commission Plans & Role Configs        -->
    <!-- Make sure the module providing these models  -->
    <!-- is declared in your manifest `depends`.     -->
    <!-- ============================================ -->

    <!-- Commission Plan - North Team -->
    <record id="commission_plan_north" model="sale.commission.plan">
      <field name="name">North Team Commission Plan</field>
      <field name="type">hierarchical</field>
      <field name="periodicity">not_applicable</field>
      <field name="require_invoice_paid">True</field>
      <field name="user_ids" eval="[(6, 0, [
        ref('user_salesperson_north_1'),
        ref('user_salesperson_north_2'),
        ref('user_salesperson_north_3'),
        ref('user_team_leader_north'),
        ref('user_sales_director_demo')
      ])]"/>
    </record>

    <!-- Role Config - North Team - Salesperson -->
    <record id="role_config_north_salesperson" model="hr.commission.role.config">
      <field name="plan_id" ref="commission_plan_north"/>
      <field name="role">salesperson</field>
      <field name="default_percentage">5.00</field>
      <field name="active">True</field>
    </record>

    <!-- Role Config - North Team - Team Leader -->
    <record id="role_config_north_team_leader" model="hr.commission.role.config">
      <field name="plan_id" ref="commission_plan_north"/>
      <field name="role">team_leader</field>
      <field name="default_percentage">3.00</field>
      <field name="active">True</field>
    </record>

    <!-- Role Config - North Team - Sales Director -->
    <record id="role_config_north_sales_director" model="hr.commission.role.config">
      <field name="plan_id" ref="commission_plan_north"/>
      <field name="role">sales_director</field>
      <field name="default_percentage">2.00</field>
      <field name="active">True</field>
    </record>

    <!-- Commission Plan - South Team -->
    <record id="commission_plan_south" model="sale.commission.plan">
      <field name="name">South Team Commission Plan</field>
      <field name="type">hierarchical</field>
      <field name="periodicity">not_applicable</field>
      <field name="require_invoice_paid">True</field>
      <field name="user_ids" eval="[(6, 0, [
        ref('user_salesperson_south_1'),
        ref('user_salesperson_south_2'),
        ref('user_salesperson_south_3'),
        ref('user_team_leader_south'),
        ref('user_sales_director_demo')
      ])]"/>
    </record>

    <!-- Role Config - South Team - Salesperson -->
    <record id="role_config_south_salesperson" model="hr.commission.role.config">
      <field name="plan_id" ref="commission_plan_south"/>
      <field name="role">salesperson</field>
      <field name="default_percentage">6.00</field>
      <field name="active">True</field>
    </record>

    <!-- Role Config - South Team - Team Leader -->
    <record id="role_config_south_team_leader" model="hr.commission.role.config">
      <field name="plan_id" ref="commission_plan_south"/>
      <field name="role">team_leader</field>
      <field name="default_percentage">2.50</field>
      <field name="active">True</field>
    </record>

    <!-- Role Config - South Team - Sales Director -->
    <record id="role_config_south_sales_director" model="hr.commission.role.config">
      <field name="plan_id" ref="commission_plan_south"/>
      <field name="role">sales_director</field>
      <field name="default_percentage">1.50</field>
      <field name="active">True</field>
    </record>

  </data>
</odoo>
