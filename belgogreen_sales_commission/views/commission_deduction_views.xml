<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Tree View -->
        <record id="view_commission_deduction_tree" model="ir.ui.view">
            <field name="name">commission.deduction.tree</field>
            <field name="model">commission.deduction</field>
            <field name="arch" type="xml">
                <list string="Commission Deductions"
                      decoration-success="state == 'applied'"
                      decoration-warning="state == 'pending'"
                      decoration-muted="state in ['waived', 'cancelled']">
                    <field name="name" string="Reference" width="120px"/>
                    <field name="user_id" string="Salesperson" width="150px"/>
                    <field name="deduction_type" string="Type" width="140px"/>
                    <field name="deduction_category" string="Category"
                           widget="badge"
                           decoration-danger="deduction_category == 'mandatory'"
                           decoration-info="deduction_category == 'optional'"
                           width="100px"/>
                    <field name="amount" string="Amount" sum="Total" width="100px"/>
                    <field name="date" string="Date" width="90px"/>
                    <field name="state" string="Status"
                           widget="badge"
                           decoration-success="state == 'applied'"
                           decoration-warning="state == 'pending'"
                           width="90px"/>
                    <field name="description" string="Description" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_commission_deduction_form" model="ir.ui.view">
            <field name="name">commission.deduction.form</field>
            <field name="model">commission.deduction</field>
            <field name="arch" type="xml">
                <form string="Commission Deduction">
                    <header>
                        <button name="action_waive"
                                string="Waive"
                                type="object"
                                invisible="state != 'pending'"
                                groups="belgogreen_sales_commission.group_commission_manager"
                                confirm="Are you sure you want to waive this deduction?"/>
                        <button name="action_set_to_pending"
                                string="Reset to Pending"
                                type="object"
                                invisible="state != 'waived'"
                                groups="belgogreen_sales_commission.group_commission_manager"/>
                        <button name="action_cancel"
                                string="Cancel"
                                type="object"
                                invisible="state in ['applied', 'cancelled']"
                                groups="belgogreen_sales_commission.group_commission_manager"
                                confirm="Are you sure you want to cancel this deduction?"/>
                        <field name="state" widget="statusbar" statusbar_visible="pending,applied"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <group string="Deduction Information">
                                <field name="user_id" options="{'no_create': True}"/>
                                <field name="deduction_type"/>
                                <field name="deduction_category"/>
                                <field name="date"/>
                            </group>
                            <group string="Amount">
                                <field name="amount" class="oe_subtotal_footer_separator"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="reference"/>
                            </group>
                        </group>

                        <group string="Description">
                            <field name="description" nolabel="1" placeholder="Enter deduction details..."/>
                        </group>

                        <!-- Waiver Information -->
                        <group string="Waiver Information" invisible="state != 'waived'">
                            <field name="waived_by" readonly="1"/>
                            <field name="waive_date" readonly="1"/>
                            <field name="waive_reason" readonly="1" nolabel="1"/>
                        </group>

                        <!-- Application Information -->
                        <group string="Application" invisible="state != 'applied'">
                            <field name="claim_id" readonly="1"/>
                            <field name="purchase_order_id" readonly="1"/>
                        </group>

                        <group string="Notes">
                            <field name="notes" nolabel="1" placeholder="Additional notes..."/>
                        </group>

                        <field name="company_id" invisible="1"/>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_commission_deduction_search" model="ir.ui.view">
            <field name="name">commission.deduction.search</field>
            <field name="model">commission.deduction</field>
            <field name="arch" type="xml">
                <search string="Commission Deductions">
                    <field name="name"/>
                    <field name="user_id"/>
                    <field name="deduction_type"/>
                    <field name="reference"/>
                    <separator/>
                    <filter string="Pending" name="pending" domain="[('state', '=', 'pending')]"/>
                    <filter string="Applied" name="applied" domain="[('state', '=', 'applied')]"/>
                    <filter string="Waived" name="waived" domain="[('state', '=', 'waived')]"/>
                    <separator/>
                    <filter string="Mandatory" name="mandatory" domain="[('deduction_category', '=', 'mandatory')]"/>
                    <filter string="Optional" name="optional" domain="[('deduction_category', '=', 'optional')]"/>
                    <separator/>
                    <filter string="Down Payments" name="down_payment" domain="[('deduction_type', '=', 'down_payment')]"/>
                    <filter string="Service Fees" name="service_fee" domain="[('deduction_type', '=', 'service_fee')]"/>
                    <separator/>
                    <filter string="This Month" name="this_month"
                            domain="[('date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                     ('date', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Salesperson" name="group_user" context="{'group_by': 'user_id'}"/>
                        <filter string="Type" name="group_type" context="{'group_by': 'deduction_type'}"/>
                        <filter string="Category" name="group_category" context="{'group_by': 'deduction_category'}"/>
                        <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Date" name="group_date" context="{'group_by': 'date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Actions -->
        <record id="action_commission_deduction" model="ir.actions.act_window">
            <field name="name">Commission Deductions</field>
            <field name="res_model">commission.deduction</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_pending': 1, 'search_default_group_user': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No deductions found
                </p>
                <p>
                    Create deductions to track down payments, service fees, and other amounts
                    to be deducted from commission payments.
                </p>
            </field>
        </record>

        <record id="action_commission_deduction_pending" model="ir.actions.act_window">
            <field name="name">Pending Deductions</field>
            <field name="res_model">commission.deduction</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'pending')]</field>
            <field name="context">{'search_default_group_user': 1}</field>
        </record>

    </data>
</odoo>
