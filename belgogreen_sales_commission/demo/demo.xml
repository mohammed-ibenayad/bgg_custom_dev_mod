    <!-- ============================================ -->
    <!-- Demo users (sales hierarchy)                -->
    <!-- Notes: - password in demo only.              -->
    <!--        - ensure custom fields exist.        -->
    <!-- ============================================ -->

    <!-- Sales Director -->
    <record id="user_sales_director_demo" model="res.users">
      <field name="name">Robert Johnson</field>
      <field name="login">director.demo</field>
      <field name="password">demo</field>
      <field name="partner_id" ref="demo_partner_robert_johnson"/>
      <field name="groups_id" eval="[
        (4, ref('base.group_user')),
        (4, ref('sales_team.group_sale_salesman'))
      ]"/>
      <!-- Custom fields used by commission module - verify they exist -->
      <field name="commission_role">sales_director</field>
    </record>

    <!-- Team Leader - North -->
    <record id="user_team_leader_north" model="res.users">
      <field name="name">Mary Wilson - North TL</field>
      <field name="login">teamleader.north</field>
      <field name="password">demo</field>
      <field name="partner_id" ref="demo_partner_mary_wilson"/>
      <field name="groups_id" eval="[
        (4, ref('base.group_user')),
        (4, ref('sales_team.group_sale_salesman'))
      ]"/>
      <field name="commission_role">team_leader</field>
      <field name="sales_director_id" ref="user_sales_director_demo"/>
    </record>

    <!-- Team Leader - South -->
    <record id="user_team_leader_south" model="res.users">
      <field name="name">Sarah Martinez - South TL</field>
      <field name="login">teamleader.south</field>
