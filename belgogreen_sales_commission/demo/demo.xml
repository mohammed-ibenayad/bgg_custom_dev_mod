      <field name="commission_role">team_leader</field>
      <field name="sales_director_id" ref="user_sales_director_demo"/>
    </record>

    <!-- Salespeople - North Team -->
    <record id="user_salesperson_north_1" model="res.users">
      <field name="name">John Anderson - North SP</field>
      <field name="login">salesperson.north.1</field>
      <field name="password">demo</field>
      <field name="partner_id" ref="demo_partner_john_anderson"/>
      <field name="groups_id" eval="[
        (4, ref('base.group_user')),
        (4, ref('sales_team.group_sale_salesman'))
      ]"/>
      <field name="commission_role">salesperson</field>
      <field name="team_leader_id" ref="user_team_leader_north"/>
      <field name="sales_director_id" ref="user_sales_director_demo"/>
    </record>

    <record id="user_salesperson_north_2" model="res.users">
      <field name="name">Emily Thompson - North SP</field>
      <field name="login">salesperson.north.2</field>
