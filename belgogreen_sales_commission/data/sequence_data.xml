<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for Sale Commission -->
        <record id="seq_sale_commission" model="ir.sequence">
            <field name="name">Sale Commission</field>
            <field name="code">sale.commission</field>
            <field name="prefix">COM/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Commission Payment -->
        <record id="seq_sale_commission_payment" model="ir.sequence">
            <field name="name">Commission Payment</field>
            <field name="code">sale.commission.payment</field>
            <field name="prefix">PAY/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Commission Claim -->
        <record id="seq_sale_commission_claim" model="ir.sequence">
            <field name="name">Commission Claim</field>
            <field name="code">sale.commission.claim</field>
            <field name="prefix">CLM/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Commission Deduction -->
        <record id="seq_commission_deduction" model="ir.sequence">
            <field name="name">Commission Deduction</field>
            <field name="code">commission.deduction</field>
            <field name="prefix">DED/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
