<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Security Groups -->
        <record id="group_commission_user" model="res.groups">
            <field name="name">Commission User</field>
            <field name="category_id" ref="base.module_category_sales_sales"/>
            <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
            <field name="comment">Users can view their own commissions and create claims</field>
        </record>

        <record id="group_commission_manager" model="res.groups">
            <field name="name">Commission Manager</field>
            <field name="category_id" ref="base.module_category_sales_sales"/>
            <field name="implied_ids" eval="[(4, ref('group_commission_user')), (4, ref('sales_team.group_sale_manager'))]"/>
            <field name="comment">Users can manage all commissions, payments, and claims</field>
        </record>

        <!-- Record Rules -->

        <!-- Commission: Users see their own commissions and their subordinates' commissions -->
        <record id="sale_commission_user_rule" model="ir.rule">
            <field name="name">User can see own and subordinate commissions</field>
            <field name="model_id" ref="model_sale_commission"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', 'in', user._get_all_subordinate_ids())]</field>
            <field name="groups" eval="[(4, ref('group_commission_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Commission: Managers see all commissions -->
        <record id="sale_commission_manager_rule" model="ir.rule">
            <field name="name">Manager can see all commissions</field>
            <field name="model_id" ref="model_sale_commission"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_commission_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Payment: Users see their own payments and their subordinates' payments -->
        <record id="sale_commission_payment_user_rule" model="ir.rule">
            <field name="name">User can see own and subordinate payments</field>
            <field name="model_id" ref="model_sale_commission_payment"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', 'in', user._get_all_subordinate_ids())]</field>
            <field name="groups" eval="[(4, ref('group_commission_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Payment: Managers see all payments -->
        <record id="sale_commission_payment_manager_rule" model="ir.rule">
            <field name="name">Manager can see all payments</field>
            <field name="model_id" ref="model_sale_commission_payment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_commission_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Claim: Users see their own claims and their subordinates' claims -->
        <record id="sale_commission_claim_user_rule" model="ir.rule">
            <field name="name">User can see own and subordinate claims</field>
            <field name="model_id" ref="model_sale_commission_claim"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', 'in', user._get_all_subordinate_ids())]</field>
            <field name="groups" eval="[(4, ref('group_commission_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Claim: Managers see all claims -->
        <record id="sale_commission_claim_manager_rule" model="ir.rule">
            <field name="name">Manager can see all claims</field>
            <field name="model_id" ref="model_sale_commission_claim"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_commission_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Role Config: Only managers can access -->
        <record id="hr_commission_role_config_manager_rule" model="ir.rule">
            <field name="name">Manager can manage role configs</field>
            <field name="model_id" ref="model_hr_commission_role_config"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_commission_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
