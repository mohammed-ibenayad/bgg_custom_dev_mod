<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit Invoice Form View -->
        <record id="view_move_form_inherit_commission" model="ir.ui.view">
            <field name="name">account.move.form.inherit.commission</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <!-- Add button in button box -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_commissions"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-sitemap"
                            invisible="commission_count == 0"
                            groups="belgogreen_sales_commission.group_commission_user">
                        <field name="commission_count" widget="statinfo" string="Commissions"/>
                    </button>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
