<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Tree View -->
        <record id="view_sale_commission_claim_tree" model="ir.ui.view">
            <field name="name">sale.commission.claim.tree</field>
            <field name="model">sale.commission.claim</field>
            <field name="arch" type="xml">
                <tree string="Commission Claims" decoration-success="state == 'paid'" decoration-warning="state == 'pending'" decoration-info="state == 'approved'" decoration-danger="state == 'rejected'">
                    <field name="name"/>
                    <field name="user_id"/>
                    <field name="claim_date"/>
                    <field name="commission_count"/>
                    <field name="total_amount" sum="Total"/>
                    <field name="state"/>
                    <field name="processed_by"/>
                    <field name="currency_id" column_invisible="True"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_sale_commission_claim_form" model="ir.ui.view">
            <field name="name">sale.commission.claim.form</field>
            <field name="model">sale.commission.claim</field>
            <field name="arch" type="xml">
                <form string="Commission Claim">
                    <header>
                        <button name="action_approve" string="Approve" type="object" class="oe_highlight"
                                invisible="state != 'pending'"
                                groups="belgogreen_sales_commission.group_commission_manager"/>
                        <button name="action_reject" string="Reject" type="object"
                                invisible="state != 'pending'"
                                groups="belgogreen_sales_commission.group_commission_manager"
                                confirm="Are you sure you want to reject this claim?"/>
                        <field name="state" widget="statusbar" statusbar_visible="pending,approved,paid"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_commissions"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-list">
                                <field name="commission_count" widget="statinfo" string="Commissions"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Claim Information">
                                <field name="user_id" readonly="1"/>
                                <field name="claim_date" readonly="1"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="total_amount" class="oe_subtotal_footer_separator"/>
                            </group>
                            <group string="Processing">
                                <field name="processed_by" readonly="1"/>
                                <field name="processed_date" readonly="1"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Commissions" name="commissions">
                                <field name="commission_ids" readonly="state != 'pending'">
                                    <tree decoration-success="payment_status == 'paid'">
                                        <field name="name"/>
                                        <field name="date"/>
                                        <field name="role"/>
                                        <field name="sale_order_id"/>
                                        <field name="base_amount"/>
                                        <field name="commission_amount" sum="Total"/>
                                        <field name="payment_status"/>
                                        <field name="currency_id" column_invisible="True"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Claimant Notes" name="notes">
                                <field name="notes" placeholder="Reason for claim..." readonly="state != 'pending'"/>
                            </page>
                            <page string="Admin Notes" name="admin_notes" groups="belgogreen_sales_commission.group_commission_manager">
                                <field name="admin_notes" placeholder="Internal notes..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_sale_commission_claim_search" model="ir.ui.view">
            <field name="name">sale.commission.claim.search</field>
            <field name="model">sale.commission.claim</field>
            <field name="arch" type="xml">
                <search string="Commission Claims">
                    <field name="name"/>
                    <field name="user_id"/>
                    <separator/>
                    <filter string="My Claims" name="my_claims" domain="[('user_id', '=', uid)]"/>
                    <separator/>
                    <filter string="Pending" name="pending" domain="[('state', '=', 'pending')]"/>
                    <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                    <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                    <filter string="Paid" name="paid" domain="[('state', '=', 'paid')]"/>
                    <group expand="0" string="Group By">
                        <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                        <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Processed By" name="group_processed" context="{'group_by': 'processed_by'}"/>
                        <filter string="Claim Date" name="group_date" context="{'group_by': 'claim_date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Kanban View -->
        <record id="view_sale_commission_claim_kanban" model="ir.ui.view">
            <field name="name">sale.commission.claim.kanban</field>
            <field name="model">sale.commission.claim</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" default_group_by="state">
                    <field name="name"/>
                    <field name="user_id"/>
                    <field name="total_amount"/>
                    <field name="claim_date"/>
                    <field name="state"/>
                    <field name="commission_count"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="user_id"/>
                                    <br/>
                                    <strong><field name="total_amount"/></strong> (<field name="commission_count"/> commissions)
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="claim_date" widget="date"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Actions -->

        <!-- All Claims (Manager) -->
        <record id="action_sale_commission_claim_all" model="ir.actions.act_window">
            <field name="name">Commission Claims</field>
            <field name="res_model">sale.commission.claim</field>
            <field name="view_mode">tree,form,kanban</field>
            <field name="context">{'search_default_pending': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No claims found
                </p>
                <p>
                    Users can claim their commissions for payment here.
                </p>
            </field>
        </record>

        <!-- My Claims (User) -->
        <record id="action_sale_commission_claim_my" model="ir.actions.act_window">
            <field name="name">My Claims</field>
            <field name="res_model">sale.commission.claim</field>
            <field name="view_mode">tree,form,kanban</field>
            <field name="context">{'search_default_my_claims': 1}</field>
            <field name="domain">[('user_id', '=', uid)]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    You haven't submitted any claims yet
                </p>
                <p>
                    You can claim your unpaid commissions for payment.
                </p>
            </field>
        </record>

    </data>
</odoo>
