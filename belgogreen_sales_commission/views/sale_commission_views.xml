<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Tree View -->
        <record id="view_sale_commission_tree" model="ir.ui.view">
            <field name="name">sale.commission.tree</field>
            <field name="model">sale.commission</field>
            <field name="arch" type="xml">
                <list string="Commissions"
                      decoration-success="payment_status == 'paid'"
                      decoration-warning="payment_status == 'claimed'"
                      decoration-muted="state == 'cancelled'"
                      create="false"
                      edit="false"
                      delete="false">
                    <field name="currency_id" column_invisible="1"/>
                    <field name="name" string="Reference" width="130px"/>
                    <field name="date" string="Date" width="90px"/>
                    <field name="user_id" string="User" width="140px"/>
                    <field name="role_id" string="Role" width="110px"/>
                    <field name="commission_type" string="Type" width="80px"/>
                    <field name="sale_order_id" string="Order" width="120px"/>
                    <field name="base_amount" string="Base" sum="Total base" width="100px"/>
                    <field name="commission_percentage" string="%" width="60px"/>
                    <field name="commission_amount" string="Commission" sum="Total commissions" width="110px"/>
                    <field name="payment_status" string="Status" width="90px"/>
                    <field name="state" string="State" optional="hide" width="80px"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_sale_commission_form" model="ir.ui.view">
            <field name="name">sale.commission.form</field>
            <field name="model">sale.commission</field>
            <field name="arch" type="xml">
                <form string="Commission">
                    <header>
                        <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state == 'cancelled'" groups="belgogreen_sales_commission.group_commission_manager"/>
                        <button name="action_claim_payment" string="Claim Payment" type="object" class="oe_highlight"
                                invisible="payment_status != 'unpaid' or state != 'confirmed'"
                                groups="belgogreen_sales_commission.group_commission_user"/>
                        <button name="action_view_claim" string="View Claim" type="object" class="oe_highlight"
                                invisible="payment_status != 'claimed' or claim_count == 0"
                                groups="belgogreen_sales_commission.group_commission_user"/>
                        <button name="action_create_payment" string="Create Payment" type="object" class="oe_highlight"
                                invisible="not can_be_paid"
                                groups="belgogreen_sales_commission.group_commission_manager"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_claim"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-files-o"
                                    invisible="claim_count == 0">
                                <field name="claim_count" widget="statinfo"
                                       string="Claim"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Commission Information">
                                <field name="user_id" readonly="1"/>
                                <field name="role_id" readonly="1"/>
                                <field name="commission_type" readonly="1"/>
                                <field name="date" readonly="1"/>
                                <field name="period" readonly="1"/>
                            </group>
                            <group string="Calculation">
                                <field name="plan_id" readonly="1"/>
                                <field name="base_amount" readonly="1"/>
                                <field name="percentage_override" groups="belgogreen_sales_commission.group_commission_manager" readonly="payment_status in ['processing', 'paid']"/>
                                <field name="commission_percentage" readonly="1"/>
                                <field name="commission_amount" class="oe_subtotal_footer_separator" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <group string="Payment Status">
                                <field name="payment_status" readonly="1"/>
                                <field name="payment_date" readonly="1"/>
                                <field name="payment_id" readonly="1"/>
                            </group>
                            <group string="References" groups="belgogreen_sales_commission.group_commission_manager">
                                <field name="sale_order_id" readonly="1"/>
                                <field name="invoice_id" readonly="1"/>
                                <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                            </group>
                        </group>
                        <group string="Notes">
                            <field name="notes" nolabel="1" placeholder="Additional notes..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_sale_commission_search" model="ir.ui.view">
            <field name="name">sale.commission.search</field>
            <field name="model">sale.commission</field>
            <field name="arch" type="xml">
                <search string="Commissions">
                    <field name="name"/>
                    <field name="user_id"/>
                    <field name="sale_order_id"/>
                    <field name="invoice_id"/>
                    <field name="period"/>
                    <separator/>
                    <filter string="My Commissions" name="my_commissions" domain="[('user_id', '=', uid)]"/>
                    <separator/>
                    <filter string="Unpaid" name="unpaid" domain="[('payment_status', '=', 'unpaid')]"/>
                    <filter string="Claimed" name="claimed" domain="[('payment_status', '=', 'claimed')]"/>
                    <filter string="Processing" name="processing" domain="[('payment_status', '=', 'processing')]"/>
                    <filter string="Paid" name="paid" domain="[('payment_status', '=', 'paid')]"/>
                    <separator/>
                    <filter string="Can Be Paid" name="can_be_paid" domain="[('can_be_paid', '=', True)]"/>
                    <separator/>
                    <filter string="Direct Sales" name="direct_sales" domain="[('commission_type', '=', 'direct')]"/>
                    <filter string="Override Commissions" name="override_commissions" domain="[('commission_type', '=', 'override')]"/>
                    <separator/>
                    <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <separator/>
                    <filter string="Current Month" name="current_month"
                            domain="[('date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                     ('date', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>
                    <filter string="Last Month" name="last_month"
                            domain="[('date', '&gt;=', (context_today() - relativedelta(months=1, day=1)).strftime('%Y-%m-%d')),
                                     ('date', '&lt;=', (context_today() - relativedelta(months=1, day=31)).strftime('%Y-%m-%d'))]"/>
                    <group expand="0" string="Group By">
                        <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                        <filter string="Role" name="group_role" context="{'group_by': 'role_id'}"/>
                        <filter string="Commission Type" name="group_commission_type" context="{'group_by': 'commission_type'}"/>
                        <filter string="Payment Status" name="group_payment_status" context="{'group_by': 'payment_status'}"/>
                        <filter string="Period" name="group_period" context="{'group_by': 'period'}"/>
                        <filter string="Plan" name="group_plan" context="{'group_by': 'plan_id'}"/>
                        <filter string="Date" name="group_date" context="{'group_by': 'date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Pivot View -->
        <record id="view_sale_commission_pivot" model="ir.ui.view">
            <field name="name">sale.commission.pivot</field>
            <field name="model">sale.commission</field>
            <field name="arch" type="xml">
                <pivot string="Commissions Analysis">
                    <field name="user_id" type="row"/>
                    <field name="period" type="col"/>
                    <field name="commission_amount" type="measure"/>
                    <field name="base_amount" type="measure"/>
                </pivot>
            </field>
        </record>

        <!-- Graph View -->
        <record id="view_sale_commission_graph" model="ir.ui.view">
            <field name="name">sale.commission.graph</field>
            <field name="model">sale.commission</field>
            <field name="arch" type="xml">
                <graph string="Commissions Analysis" type="bar">
                    <field name="period"/>
                    <field name="commission_amount" type="measure"/>
                </graph>
            </field>
        </record>

        <!-- Kanban View -->
        <record id="view_sale_commission_kanban" model="ir.ui.view">
            <field name="name">sale.commission.kanban</field>
            <field name="model">sale.commission</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" create="false">
                    <field name="name"/>
                    <field name="user_id"/>
                    <field name="role_id"/>
                    <field name="commission_type"/>
                    <field name="commission_amount"/>
                    <field name="payment_status"/>
                    <field name="date"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    </div>
                                    <span class="float-end badge badge-pill"
                                          t-attf-class="#{record.payment_status.raw_value == 'paid' ? 'badge-success' : record.payment_status.raw_value == 'claimed' ? 'badge-warning' : 'badge-secondary'}">
                                        <field name="payment_status"/>
                                    </span>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="user_id"/> - <field name="role_id"/> (<field name="commission_type"/>)
                                    <br/>
                                    <strong><field name="commission_amount"/></strong>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="date"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Actions -->

        <!-- All Commissions (Manager View) -->
        <record id="action_sale_commission_all" model="ir.actions.act_window">
            <field name="name">All Commissions</field>
            <field name="res_model">sale.commission</field>
            <field name="view_mode">list,form,kanban,pivot,graph</field>
            <field name="context">{'search_default_confirmed': 1, 'search_default_group_user': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No commissions found
                </p>
                <p>
                    Commissions are automatically created when invoices are paid.
                </p>
            </field>
        </record>

        <!-- My Commissions (User View) -->
        <record id="action_sale_commission_my" model="ir.actions.act_window">
            <field name="name">My Commissions</field>
            <field name="res_model">sale.commission</field>
            <field name="view_mode">list,form,kanban,pivot,graph</field>
            <field name="context">{'search_default_my_commissions': 1, 'search_default_group_period': 1}</field>
            <field name="domain">[('user_id', '=', uid)]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    You don't have any commissions yet
                </p>
                <p>
                    Your commissions will appear here once sales orders are invoiced and paid.
                </p>
            </field>
        </record>

        <!-- Unpaid Commissions (Manager View) -->
        <record id="action_sale_commission_unpaid" model="ir.actions.act_window">
            <field name="name">Unpaid Commissions</field>
            <field name="res_model">sale.commission</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_can_be_paid': 1, 'search_default_group_user': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No unpaid commissions
                </p>
            </field>
        </record>

        <!-- Team Commissions (Supervisor View) -->
        <!-- Note: This action shows all commissions visible to the current user based on record rules.
             The actual filtering happens automatically via the hierarchical record rules. -->
        <record id="action_sale_commission_team" model="ir.actions.act_window">
            <field name="name">Team Commissions</field>
            <field name="res_model">sale.commission</field>
            <field name="view_mode">list,form,kanban,pivot,graph</field>
            <field name="context">{'search_default_group_user': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No team commissions found
                </p>
                <p>
                    Your team's commissions will appear here once sales orders are invoiced and paid.
                    You will see commissions for all users in your hierarchy.
                </p>
            </field>
        </record>

    </data>
</odoo>
