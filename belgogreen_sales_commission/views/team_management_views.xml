<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Team Hierarchy Tree View -->
        <record id="view_team_hierarchy_tree" model="ir.ui.view">
            <field name="name">team.hierarchy.tree</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <list string="Structure des équipes"
                      decoration-muted="not commission_role_id"
                      create="false">
                    <field name="name" string="Nom" width="150px"/>
                    <field name="commission_role_id" string="Rôle" width="120px"/>
                    <field name="commission_manager_id" string="Manager" width="130px"/>
                    <field name="subordinate_count" string="Nb. subordonnés" width="100px"/>
                    <field name="active_commission_count" string="Com. actives" width="100px"/>
                    <field name="commission_unpaid_total" string="Non payé" sum="Total non payé" width="110px"/>
                    <field name="team_unpaid_total" string="Équipe non payée" sum="Total équipe" width="120px"/>
                </list>
            </field>
        </record>

        <!-- Team Hierarchy Kanban View -->
        <record id="view_team_hierarchy_kanban" model="ir.ui.view">
            <field name="name">team.hierarchy.kanban</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" create="false">
                    <field name="name"/>
                    <field name="commission_role_id"/>
                    <field name="commission_manager_id"/>
                    <field name="subordinate_count"/>
                    <field name="active_commission_count"/>
                    <field name="commission_unpaid_total"/>
                    <field name="team_unpaid_total"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><field name="name"/></strong>
                                        <br/>
                                        <span class="badge badge-info" t-if="record.commission_role_id.value">
                                            <field name="commission_role_id"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div t-if="record.commission_manager_id.value">
                                        <strong>Manager :</strong> <field name="commission_manager_id"/>
                                    </div>
                                    <div t-if="record.subordinate_count.value > 0">
                                        <strong>Subordonnés :</strong> <field name="subordinate_count"/>
                                    </div>
                                    <div>
                                        <strong>Com. actives :</strong> <field name="active_commission_count"/>
                                    </div>
                                    <div>
                                        <strong>Non payé :</strong> <field name="commission_unpaid_total"/>
                                    </div>
                                    <div t-if="record.team_unpaid_total.value > 0">
                                        <strong>Équipe non payée :</strong> <field name="team_unpaid_total"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Team Hierarchy Search View -->
        <record id="view_team_hierarchy_search" model="ir.ui.view">
            <field name="name">team.hierarchy.search</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <search string="Structure des équipes">
                    <field name="name"/>
                    <field name="commission_role_id"/>
                    <field name="commission_manager_id"/>
                    <separator/>
                    <filter string="With Commission Role" name="has_role" domain="[('commission_role_id', '!=', False)]"/>
                    <filter string="With Manager" name="has_manager" domain="[('commission_manager_id', '!=', False)]"/>
                    <filter string="Has Subordinates" name="has_subordinates" domain="[('subordinate_count', '>', 0)]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Commission Role" name="group_role" context="{'group_by': 'commission_role_id'}"/>
                        <filter string="Manager" name="group_manager" context="{'group_by': 'commission_manager_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Team Hierarchy Action -->
        <record id="action_team_hierarchy" model="ir.actions.act_window">
            <field name="name">Structure des équipes</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="domain">[('commission_role_id', '!=', False)]</field>
            <field name="context">{'search_default_group_manager': 1, 'create': False}</field>
            <field name="search_view_id" ref="view_team_hierarchy_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Aucune hiérarchie de commission définie
                </p>
                <p>
                    Configurez la hiérarchie de votre équipe commerciale en assignant des rôles de commission aux utilisateurs.
                </p>
            </field>
        </record>

        <!-- Team Management Dashboard View (Graph) -->
        <record id="view_team_management_graph" model="ir.ui.view">
            <field name="name">team.management.graph</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <graph string="Team Performance" type="bar">
                    <field name="commission_role_id" type="row"/>
                    <field name="commission_unpaid_total" type="measure"/>
                </graph>
            </field>
        </record>

        <!-- Team Management Dashboard Action -->
        <record id="action_team_management_dashboard" model="ir.actions.act_window">
            <field name="name">Gestion des managers</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">kanban,list,graph,form</field>
            <field name="domain">[('commission_role_id.can_manage_subordinates', '=', True)]</field>
            <field name="context">{'create': False}</field>
            <field name="search_view_id" ref="view_team_hierarchy_search"/>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_team_hierarchy_kanban')}),
                (0, 0, {'view_mode': 'list', 'view_id': ref('view_team_hierarchy_tree')}),
                (0, 0, {'view_mode': 'graph', 'view_id': ref('view_team_management_graph')})]"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Aucune équipe trouvée
                </p>
                <p>
                    Les équipes apparaîtront ici une fois que vous aurez assigné des rôles de gestion avec des subordonnés.
                </p>
            </field>
        </record>

        <!-- Hierarchy Anomalies List View -->
        <record id="view_hierarchy_anomalies_tree" model="ir.ui.view">
            <field name="name">hierarchy.anomalies.tree</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <list string="Anomalies Hiérarchiques"
                      decoration-warning="anomaly_type == 'manager_lower_level'"
                      decoration-danger="anomaly_type in ['missing_manager', 'top_role_has_manager', 'circular_hierarchy']"
                      decoration-muted="anomaly_type == 'no_role_with_manager'"
                      create="false"
                      edit="false">
                    <field name="name" string="Nom"/>
                    <field name="commission_role_id" string="Rôle"/>
                    <field name="anomaly_type" string="Type d'anomalie"/>
                    <field name="anomaly_description" string="Description" widget="text"/>
                    <field name="commission_manager_id" string="Manager"/>
                    <field name="subordinate_count" string="Subordonnés"/>
                </list>
            </field>
        </record>

        <!-- Hierarchy Anomalies Search View -->
        <record id="view_hierarchy_anomalies_search" model="ir.ui.view">
            <field name="name">hierarchy.anomalies.search</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <search string="Anomalies Hiérarchiques">
                    <field name="name"/>
                    <field name="commission_role_id"/>
                    <field name="anomaly_type"/>
                    <separator/>
                    <filter string="Manager manquant" name="missing_manager"
                            domain="[('anomaly_type', '=', 'missing_manager')]"/>
                    <filter string="Rôle top avec manager" name="top_role_has_manager"
                            domain="[('anomaly_type', '=', 'top_role_has_manager')]"/>
                    <filter string="Pas de rôle avec manager" name="no_role_with_manager"
                            domain="[('anomaly_type', '=', 'no_role_with_manager')]"/>
                    <filter string="Manager de niveau inférieur" name="manager_lower_level"
                            domain="[('anomaly_type', '=', 'manager_lower_level')]"/>
                    <filter string="Hiérarchie circulaire" name="circular_hierarchy"
                            domain="[('anomaly_type', '=', 'circular_hierarchy')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Type d'anomalie" name="group_anomaly_type" context="{'group_by': 'anomaly_type'}"/>
                        <filter string="Rôle de commission" name="group_role" context="{'group_by': 'commission_role_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Hierarchy Anomalies Action -->
        <record id="action_hierarchy_anomalies" model="ir.actions.act_window">
            <field name="name">Anomalies Hiérarchiques</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('has_hierarchy_anomaly', '=', True)]</field>
            <field name="context">{'search_default_group_anomaly_type': 1, 'create': False, 'edit': False}</field>
            <field name="search_view_id" ref="view_hierarchy_anomalies_search"/>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('view_hierarchy_anomalies_tree')})]"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Aucune anomalie hiérarchique détectée
                </p>
                <p>
                    Les utilisateurs avec des problèmes d'assignation hiérarchique apparaîtront ici.
                </p>
                <p>
                    <strong>Types d'anomalies détectées:</strong><br/>
                    • Manager manquant: Rôle requiert un manager mais aucun assigné<br/>
                    • Rôle top avec manager: Rôle de niveau supérieur ne devrait pas avoir de manager<br/>
                    • Pas de rôle avec manager: Manager assigné sans rôle de commission<br/>
                    • Manager de niveau inférieur: Manager a un niveau de hiérarchie inférieur<br/>
                    • Hiérarchie circulaire: Utilisateur dans sa propre chaîne de management
                </p>
            </field>
        </record>

    </data>
</odoo>
