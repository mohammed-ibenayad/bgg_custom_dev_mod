<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit User Form View -->
        <record id="view_users_form_inherit_commission" model="ir.ui.view">
            <field name="name">res.users.form.inherit.commission</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <!-- Add commission fields in Preferences notebook -->
                <xpath expr="//page[@name='preferences']" position="after">
                    <page string="Commission Hierarchy" name="commission_hierarchy" groups="belgogreen_sales_commission.group_commission_manager">
                        <!-- Hidden fields for computation -->
                        <field name="has_subordinates" invisible="1"/>

                        <!-- Hierarchy Warnings Alert -->
                        <div class="alert alert-warning" role="alert" invisible="not hierarchy_warnings">
                            <strong>⚠️ Hierarchy Issues:</strong>
                            <field name="hierarchy_warnings" nolabel="1" readonly="1"/>
                        </div>

                        <group>
                            <group string="Commission Role">
                                <field name="commission_role_id"/>
                                <field name="active_commission_count" readonly="1"/>
                                <field name="subordinate_count" readonly="1" invisible="subordinate_count == 0"/>
                            </group>
                            <group string="Hierarchy">
                                <field name="commission_manager_id" invisible="not commission_role_id or (commission_role_id and not commission_role_id.requires_manager)"/>
                            </group>
                        </group>
                        <group string="Direct Subordinates" invisible="not commission_role_id or (commission_role_id and not commission_role_id.can_manage_subordinates)">
                            <field name="commission_subordinate_ids" nolabel="1" options="{'no_create': True}">
                                <list>
                                    <field name="name" string="Name" width="180px"/>
                                    <field name="commission_role_id" string="Role" width="120px"/>
                                    <field name="commission_unpaid_total" string="Unpaid" width="110px"/>
                                </list>
                            </field>
                        </group>
                        <group string="Commission Statistics">
                            <group string="My Commissions">
                                <field name="commission_count"/>
                                <field name="commission_unpaid_total"/>
                                <field name="commission_paid_total"/>
                            </group>
                            <group string="Team Commissions" invisible="not commission_role_id or (commission_role_id and not commission_role_id.can_manage_subordinates)">
                                <field name="team_commission_count"/>
                                <field name="team_unpaid_total"/>
                            </group>
                        </group>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_my_commissions"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-money"
                                    invisible="commission_count == 0">
                                <field name="commission_count" widget="statinfo" string="My Commissions"/>
                            </button>
                            <button name="action_view_team_commissions"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-users"
                                    invisible="team_commission_count == 0">
                                <field name="team_commission_count" widget="statinfo" string="Team Commissions"/>
                            </button>
                        </div>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
